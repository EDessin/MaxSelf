FROM golang:1.26-alpine AS build

WORKDIR /src
RUN apk add --no-cache ca-certificates

COPY go.mod go.sum ./
RUN go mod download

COPY . .
ARG SERVICE=api
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/service ./cmd/${SERVICE}

FROM alpine:3.22

RUN apk add --no-cache ca-certificates
COPY --from=build /out/service /usr/local/bin/maxself-service

EXPOSE 8080
ENTRYPOINT ["/usr/local/bin/maxself-service"]
